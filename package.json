{
  "name": "apoya-a-tu-streamer",
  "version": "1.0.8",
  "description": "Monitor y lanzador legítimo de directos de Twitch y Kick",
  "main": "dist-electron/main/index.js",
  "author": "Vortex Studio",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:electron": "esbuild electron/main/index.ts --bundle --platform=node --format=esm --external:electron --outfile=dist-electron/main/index.js && esbuild electron/preload/index.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/preload/index.js",
    "build": "npm run typecheck && vite build && npm run build:electron && electron-builder --dir --publish never",
    "build:extension": "powershell -NoProfile -ExecutionPolicy Bypass -File browser-extension/build.ps1",
    "test:extension": "vitest run src/domain/browser-protocol.test.ts",
    "package:extension": "powershell -NoProfile -ExecutionPolicy Bypass -File browser-extension/package.ps1",
    "build:native-host": "esbuild native-host/src/index.ts --bundle --platform=node --format=cjs --outfile=native-host/dist/native-host.cjs && powershell -NoProfile -ExecutionPolicy Bypass -Command \"Copy-Item -Force (Get-Command node.exe).Source native-host/dist/node.exe\"",
    "test:native-host": "vitest run native-host/src/framing.test.ts native-host/scripts/native-host-cli.test.ts electron/main/browser-extension-client.test.ts",
    "native-host:register": "node native-host/scripts/native-host-cli.mjs register",
    "native-host:unregister": "node native-host/scripts/native-host-cli.mjs unregister",
    "native-host:doctor": "node native-host/scripts/native-host-cli.mjs doctor",
    "build:win": "npm run typecheck && vite build && npm run build:electron && npm run build:extension && npm run build:native-host && electron-builder --win nsis portable --publish never && npm run package:extension",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "electron-store": "^10.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "esbuild": "latest",
    "eslint": "latest",
    "@eslint/js": "latest",
    "typescript-eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "prettier": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "build": {
    "appId": "es.vortexstudio.apoyaatustreamer",
    "productName": "Apoya a tu Streamer",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "native-host/dist/**/*",
      "native-host/manifests/**/*",
      "native-host/scripts/**/*",
      "browser-extension/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "native-host/dist", "to": "native-host" },
      { "from": "native-host/manifests", "to": "native-host/manifests" },
      { "from": "native-host/scripts", "to": "native-host/scripts" },
      { "from": "native-host/native-host.cmd", "to": "native-host/native-host.cmd" },
      { "from": "native-host/host-config.json", "to": "native-host/host-config.json" },
      { "from": "browser-extension/dist", "to": "browser-extension" }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "Apoya-a-tu-Streamer-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "native-host/installer.nsh"
    },
    "portable": {
      "artifactName": "Apoya-a-tu-Streamer-Portable-${version}-${arch}.${ext}"
    }
  }
}
