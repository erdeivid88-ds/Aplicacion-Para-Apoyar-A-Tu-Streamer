{
  "manifest_version": 3,
  "name": "Apoya a tu Streamer",
  "version": "1.0.8",
  "key": "",
  "description": "Controla exclusivamente pestañas abiertas por Apoya a tu Streamer.",
  "permissions": ["tabs", "storage", "nativeMessaging"],
  "host_permissions": ["https://www.twitch.tv/*", "https://twitch.tv/*", "https://kick.com/*", "https://www.kick.com/*"],
  "background": { "service_worker": "service-worker.js" },
  "action": { "default_popup": "popup.html" },
  "options_page": "options.html",
  "content_security_policy": { "extension_pages": "script-src 'self'; object-src 'self'" }
}
